        "request": {
          "query": "\nprefix bbo: <http://www.onto-bpo.eu/ontologies/bbo#>\nprefix bboExt: <http://www.onto-bpo.eu/ontologies/bboExtension#>\nprefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nprefix tai: <https://www.teamingai-project.eu/>\nprefix xsd: <http://www.w3.org/2001/XMLSchema#>\nSELECT ?org ?orgName (COUNT(DISTINCT ?model) AS ?modelCount) WHERE {\n  ?org a bboExt:Organization .\n  OPTIONAL { ?org rdfs:label ?orgName . }\n  ?model a bboExt:Model .\n  ?model tai:belongsTo ?org .\n}\nGROUP BY ?org ?orgName\nHAVING (COUNT(DISTINCT ?model) >= 5 && COUNT(DISTINCT ?model) <= 10)\nORDER BY DESC(?modelCount)\n"
