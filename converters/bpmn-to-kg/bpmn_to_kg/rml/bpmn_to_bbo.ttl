@prefix teamingAI:        <https://www.teamingai-project.eu/> .

@prefix rml:        <http://semweb.mmlab.be/ns/rml#> .

@prefix rr:         <http://www.w3.org/ns/r2rml#> .

@prefix ql:         <http://semweb.mmlab.be/ns/ql#> .

@prefix rdf:        <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .

@prefix rdfs:       <http://www.w3.org/2000/01/rdf-schema#> .

@prefix schema:     <http://schema.org/> .

@prefix dbo:        <http://dbpedia.org/ontology/> .

@prefix bbo:        <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .

@prefix dc:         <http://purl.org/dc/elements/1.1/> .

@prefix rami: <https://w3id.org/i40/rami#> .




<https://www.teamingai-project.eu/bpmn_to_bbo#>
    dc:title        "BPMN to BBO"@en ;
    dc:date         "2021-11-04" ;
    dc:description  "This is the RML mapping from Business Process Model and Notation (BPMN) to Business Process Model and Notation Based Ontology (BBO)"@en .



teamingAI:ProcessMapping
    a   rr:TriplesMap ;

    rml:logicalSource [
        rml:source                  "/home/bachhofner/Dev/business-process-management-to-knowledge-graph/bpmn/farplas/process_without_messages.bpmn" ;
        rml:referenceFormulation    ql:XPath ;
        rml:iterator                "/*[name()='bpmn:definitions']/*[name()='bpmn:process']"
    ] ;

    rr:subjectMap [
        rr:template                 "https://www.teamingai-project.eu/kg/process/qualityInspection/{@id}"
    ] ;

    rr:predicateObjectMap [
        rr:predicate        rdfs:subClassOf ;
        rr:objectMap [
            rr:constant     bbo:Process
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate        rdfs:comment ;
        rr:objectMap [
            rr:constant     "representation of a business process using business process model and notation business ontology"
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate        teamingAI:belongsToRAMILayer ;
        rr:objectMap [
            rr:constant     rami:Business
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate        teamingAI:belongsToView ;
        rr:objectMap [
            rr:constant     teamingAI:BusinessProcessManagementView
        ]
    ] .



teamingAI:SubProcessMapping
    a   rr:TriplesMap ;

    rml:logicalSource [
        rml:source                  "/home/bachhofner/Dev/business-process-management-to-knowledge-graph/bpmn/farplas/process_without_messages.bpmn" ;
        rml:referenceFormulation    ql:XPath ;
        rml:iterator                "/*[name()='bpmn:definitions']/*[name()='bpmn:process']/*[name()='bpmn:subProcess']"
    ] ;

    rr:subjectMap [
        rr:template                 "https://www.teamingai-project.eu/kg/process/qualityInspection/{@id}"
    ] ;

    rr:predicateObjectMap [
        rr:predicate        rdfs:subClassOf ;
        rr:objectMap [
            rr:constant     bbo:SubProcess
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate        rdfs:comment ;
        rr:objectMap [
            rr:constant     "a process that is included within another process."
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate        teamingAI:belongsToRAMILayer ;
        rr:objectMap [
            rr:constant     rami:Business
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate        teamingAI:belongsToView ;
        rr:objectMap [
            rr:constant     teamingAI:BusinessProcessManagementView
        ]
    ] .



teamingAI:ErrorMapping
    a   rr:TriplesMap ;

    rml:logicalSource [
        rml:source                  "/home/bachhofner/Dev/business-process-management-to-knowledge-graph/bpmn/farplas/process_without_messages.bpmn" ;
        rml:referenceFormulation    ql:XPath ;
        rml:iterator                "/*[name()='bpmn:definitions']/*[name()='bpmn:error']"
    ] ;

    rr:subjectMap [
        rr:template                 "https://www.teamingai-project.eu/kg/process/qualityInspection/{@id}"
    ] ;

    rr:predicateObjectMap [
        rr:predicate        rdfs:subClassOf ;
        rr:objectMap [
            rr:constant     bbo:Error
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate        rdfs:label ;
        rr:objectMap [
            rr:constant    "error"@en 
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate        rdfs:comment ;
        rr:objectMap [
            rr:constant     "An Error represents the content of an Error Event or the Fault of a failed Operation. An ItemDefinition is used to specify the structure of the Error. An Error is generated when there is a critical problem in the processing of an Activity or when the execution of an Operation failed."@en
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate        bbo:name ;
        rr:objectMap [
            rml:reference   "@name"
        ]
    ]
 .



teamingAI:PropertyMapping
    a   rr:TriplesMap ;

    rml:logicalSource [
        rml:source                  "/home/bachhofner/Dev/business-process-management-to-knowledge-graph/bpmn/farplas/process_without_messages.bpmn" ;
        rml:referenceFormulation    ql:XPath ;
        rml:iterator                "/*[name()='bpmn:definitions']/*[name()='bpmn:process']//*[name()='bpmn:property']"
    ] ;

    rr:subjectMap [
        rr:template                 "https://www.teamingai-project.eu/kg/process/qualityInspection/{@id}"
    ] ;

    rr:predicateObjectMap [
        rr:predicate        rdfs:subClassOf ;
        rr:objectMap [
            rr:constant     bbo:Property
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate        rdfs:label ;
        rr:objectMap [
            rr:constant    "property"@en 
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate        bbo:name ;
        rr:objectMap [
            rml:reference   "@name"
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate        bbo:has_property_element ;
        rr:objectMap [
            rr:template     "{../@id}"
        ]
    ]
 .



#################################################################################################################
#
# Event Mappings
#
#################################################################################################################



teamingAI:StartEventMapping
    a rr:TriplesMap ;
    rml:logicalSource [
        rml:source                  "/home/bachhofner/Dev/business-process-management-to-knowledge-graph/bpmn/farplas/process_without_messages.bpmn" ;
        rml:referenceFormulation    ql:XPath ;
        rml:iterator                "/*[name()='bpmn:definitions']/*[name()='bpmn:process']/*[name()='bpmn:startEvent']"
    ] ;

    rr:subjectMap [
        rr:template                 "https://www.teamingai-project.eu/kg/process/qualityInspection/{@id}"
    ] ;

    rr:predicateObjectMap [
        rr:predicate        rdfs:subClassOf ;
        rr:objectMap [
            rr:constant     bbo:StartEvent
        ] 
    ] ;

    rr:predicateObjectMap [
        rr:predicate        rdfs:label ;
        rr:objectMap [
            rr:constant     "start event" ;
            rr:language     "en"
        ]
    ] ;
    
    rr:predicateObjectMap [
        rr:predicate        bbo:has_targetRef ;
        rr:objectMap [
            rr:template     "https://www.teamingai-project.eu/kg/process/qualityInspection/{*[text()]}" ;
        ]
    ] ;
    
    rr:predicateObjectMap [
        rr:predicate        rdfs:comment ;
        rr:objectMap [
            rr:constant     "The Start Event indicates where a particular Process will start. In terms of Sequence Flows, the Start Event starts the flow of the Process, and thus, will not have any incoming Sequence Flows—no Sequence Flow can connect to a Start Event." ;
            rr:language     "en"
        ]
    ] ;
    
    rr:predicateObjectMap [
        rr:predicate        teamingAI:belongsToProcess ;
        rr:objectMap [
            rr:parentTriplesMap teamingAI:ProcessMapping
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate                    bbo:name ;
        rr:objectMap [
            rml:reference               "@name" ;
        ]
    ] .





teamingAI:EndEventMapping
    a rr:TriplesMap ;
    rml:logicalSource [
        rml:source                  "/home/bachhofner/Dev/business-process-management-to-knowledge-graph/bpmn/farplas/process_without_messages.bpmn" ;
        rml:referenceFormulation    ql:XPath;
        rml:iterator                "/*[name()='bpmn:definitions']/*[name()='bpmn:process']/*[name()='bpmn:endEvent']"
    ] ;


    rr:subjectMap [
        rr:template                 "https://www.teamingai-project.eu/kg/process/qualityInspection/{@id}"
    ] ;

    rr:predicateObjectMap [
        rr:predicate        rdfs:subClassOf ;
        rr:objectMap [
            rr:constant     bbo:EndEvent
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate        rdfs:label ;
        rr:objectMap [
            rr:constant     "end event" ;
            rr:language     "en"
        ]
    ] ;
    
    rr:predicateObjectMap [
        rr:predicate        rdfs:comment ;
        rr:objectMap [
            rr:constant     "The End Event indicates where a Process will end. In terms of Sequence Flows, the End Event ends the flow of the Process, and thus, will not have any outgoing Sequence Flows—no Sequence Flow can connect from an End Event." ;
            rr:language     "en"
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate        teamingAI:belongsToProcess ;
        rr:objectMap [
            rr:parentTriplesMap teamingAI:ProcessMapping
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate                    bbo:name ;
        rr:objectMap [
            rml:reference               "@name" ;
        ]
    ] .



teamingAI:BoundaryEventMapping
    a rr:TriplesMap ;

    rml:logicalSource [
        rml:source                  "/home/bachhofner/Dev/business-process-management-to-knowledge-graph/bpmn/farplas/process_without_messages.bpmn" ;
        rml:referenceFormulation    ql:XPath;
        rml:iterator                "/*[name()='bpmn:definitions']/*[name()='bpmn:process']/*[name()='bpmn:boundaryEvent']"
    ] ;


    rr:subjectMap [
        rr:template                 "https://www.teamingai-project.eu/kg/process/qualityInspection/{@id}"
    ] ;

    rr:predicateObjectMap [
        rr:predicate        rdfs:subClassOf ;
        rr:objectMap [
            rr:constant     bbo:BoundaryEvent
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate        rdfs:label ;
        rr:objectMap [
            rr:constant     "boundary event" ;
            rr:language     "en"
        ]
    ] ;
    
    rr:predicateObjectMap [
        rr:predicate        bbo:attachedToRef ;
        rr:objectMap [
            rr:template     "{@attachedToRef}" 
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate                    bbo:name ;
        rr:objectMap [
            rml:reference               "@name" ;
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate                    bbo:has_targetRef ;
        rr:objectMap [
            rr:template     "{./*[name()='bpmn:outgoing']}"
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate                    bbo:has_eventDefinition ;
        rr:objectMap [
            rr:template     "{./*[name()='bpmn:messageEventDefinition']/@id}"
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate                    bbo:has_eventDefinition ;
        rr:objectMap [
            rr:template     "{./*[name()='bpmn:errorEventDefinition']/@id}"
        ]
    ]
.



