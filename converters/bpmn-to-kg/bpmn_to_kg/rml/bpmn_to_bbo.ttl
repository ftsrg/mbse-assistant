    ] ;

    rr:predicateObjectMap [
        rr:predicate            rdfs:subClassOf ;
        rr:objectMap [
            rr:constant         bbo:SequenceFlow
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate            rdfs:label ;
        rr:objectMap [
            rr:constant         "incoming" ;
            rr:language         "en"
        ]
    ] ;
    
    rr:predicateObjectMap [
        rr:predicate            rdfs:comment ;
        rr:objectMap [
            rr:constant         "A Sequence Flow is used to show the order of Flow Elements in a Process or a Choreography. Each Sequence Flow has only one source and only one target. The source and target MUST be from the set of the following Flow Elements: Events (Start, Intermediate, and End), Activities (Task and Sub-Process; for Processes), Choreography Activities (Choreography Task and Sub-Choreography; for Choreographies), and Gateways." ;
            rr:language         "en"
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate        teamingAI:belongsToProcess ;
        rr:objectMap [
            rr:parentTriplesMap teamingAI:ProcessMapping
        ]
    ] .


#################################################################################################################
#
# Task Mappings
#
#################################################################################################################



teamingAI:TaskMapping
    a   rr:TriplesMap ;

    rml:logicalSource [
        rml:source                  "" ;
        rml:referenceFormulation    ql:XPath ;
        rml:iterator                "/*[name()='bpmn:definitions']/*[name()='bpmn:process']//*[name()='bpmn:task']"
    ] ;

    rr:subjectMap [
        rr:template                 "https://www.teamingai-project.eu/kg/process/qualityInspection/{@id}"
    ] ;

    rr:predicateObjectMap [
        rr:predicate                rdfs:subClassOf ;
        rr:objectMap [
            rr:constant             bbo:Task
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate                rdfs:label ;
        rr:objectMap [
            rr:constant             "task" ;
            rr:language             "en"
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate                rdfs:comment ;
        rr:objectMap [
            rr:constant             "A Task is an atomic Activity within a Process flow. A Task is used when the work in the Process cannot be broken down to a finer level of detail. Generally, an end-user and/or applications are used to perform the Task when it is executed." ;
            rr:language             "en"
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate                    bbo:name ;
        rr:objectMap [
            rml:reference               "@name" ;
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate        teamingAI:belongsToProcess ;
        rr:objectMap [
            rr:parentTriplesMap teamingAI:ProcessMapping
        ]
    ] .





teamingAI:ServiceTaskMapping
    a   rr:TriplesMap ;

    rml:logicalSource [
        rml:source                  "/home/bachhofner/Dev/business-process-management-to-knowledge-graph/bpmn/farplas/process_without_messages.bpmn" ;
        rml:referenceFormulation     ql:XPath ;
        rml:iterator                "/*[name()='bpmn:definitions']/*[name()='bpmn:process']//*[name()='bpmn:serviceTask']"
    ] ;


    rr:subjectMap [
