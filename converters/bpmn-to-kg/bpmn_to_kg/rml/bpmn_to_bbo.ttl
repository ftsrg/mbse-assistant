#################################################################################################################
#
# Gateway Mappings
#
#################################################################################################################



teamingAI:ParallelGatewayMapping
    a   rr:TriplesMap ;

    rml:logicalSource [
        rml:source                      "/home/bachhofner/Dev/business-process-management-to-knowledge-graph/bpmn/farplas/process_without_messages.bpmn" ;
        rml:referenceFormulation        ql:XPath ;
        rml:iterator                    "/*[name()='bpmn:definitions']/*[name()='bpmn:process']/*[name()='bpmn:parallelGateway']"
    ] ;

    rr:subjectMap [
        rr:template                     "https://www.teamingai-project.eu/kg/process/qualityInspection/{@id}"
    ] ;

    rr:predicateObjectMap [
        rr:predicate                    rdfs:subClassOf ;
        rr:objectMap [
            rr:constant                 bbo:ParallelGateway
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate                    rdfs:label ;
        rr:objectMap [
            rr:constant                 "parallel gateway" ;
            rr:language                 "en"
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate                    rdfs:comment ;
        rr:objectMap [
            rr:constant                 "A Parallel Gateway is used to synchronize (combine) parallel flows and to create parallel flows. A Parallel Gateway creates parallel paths without checking any conditions; each outgoing Sequence Flow receives a token upon execution of this Gateway. For incoming flows, the Parallel Gateway will wait for all incoming flows before triggering the flow through its outgoing Sequence Flows." ;
            rr:language                 "en"
        ]
    ]  ;

    rr:predicateObjectMap [
        rr:predicate                    bbo:DefaultSequenceFlow ;
        rr:objectMap [
            rr:template                 "{@default}"
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate        teamingAI:belongsToProcess ;
        rr:objectMap [
            rr:parentTriplesMap teamingAI:ProcessMapping
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate        bbo:name ;
        rr:objectMap [
            rml:reference     "@name"
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate        bbo:has_targetRef ;
        rr:objectMap [
            rr:template     "{./*[name()='bpmn:outgoing']}" ;
        ]
    ] ;
    
    rr:predicateObjectMap [
        rr:predicate        bbo:has_sourceRef ;
        rr:objectMap [
            rr:template     "{./*[name()='bpmn:incoming']}" ;
        ]
    ] .





teamingAI:eXlusiveORGatewayMapping
    a   rr:TriplesMap ;

    rml:logicalSource [
        rml:source                      "/home/bachhofner/Dev/business-process-management-to-knowledge-graph/bpmn/farplas/process_without_messages.bpmn" ;
        rml:referenceFormulation        ql:XPath ;
        rml:iterator                    "/*[name()='bpmn:definitions']/*[name()='bpmn:process']//*[name()='bpmn:exclusiveGateway']" ;
    ] ;

    rr:subjectMap [
        rr:template                     "https://www.teamingai-project.eu/kg/process/qualityInspection/{@id}"
    ] ;

    rr:predicateObjectMap [
        rr:predicate                    rdfs:subClassOf ;
        rr:objectMap [
            rr:constant                 bbo:ExclusiveGateway
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate                    rdfs:label ;
        rr:objectMap [
            rr:constant                 "exclusive or gateway";
            rr:language                 "en"
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate                    rdfs:comment ;
        rr:objectMap [
            rr:constant                 "A diverging Exclusive Gateway (Decision) is used to create alternative paths within a Process flow. This is basically the “diversion point in the road” for a Process. For a given instance of the Process, only one of the paths can be taken." ;
            rr:language                 "en"
        ]
    ]  ;

    rr:predicateObjectMap [
        rr:predicate        teamingAI:belongsToProcess ;
        rr:objectMap [
            rr:parentTriplesMap teamingAI:ProcessMapping
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate                    bbo:DefaultSequenceFlow ;
        rr:objectMap [
            rr:template                 "{@default}"
        ]
    ] ;    

    rr:predicateObjectMap [
        rr:predicate        bbo:name ;
        rr:objectMap [
            rml:reference     "@name"
        ]
    ] ;
    
    rr:predicateObjectMap [
        rr:predicate        bbo:has_targetRef ;
        rr:objectMap [
            rr:template     "{./*[name()='bpmn:outgoing']}" ;
        ]
    ] ;
    
    rr:predicateObjectMap [
        rr:predicate        bbo:has_sourceRef ;
        rr:objectMap [
            rr:template     "{./*[name()='bpmn:incoming']}" ;
        ]
    ] 
.
