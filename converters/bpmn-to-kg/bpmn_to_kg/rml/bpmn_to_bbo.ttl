    ] ;

    rr:predicateObjectMap [
        rr:predicate                rdfs:subClassOf ;
        rr:objectMap [
            rr:constant             bbo:ServiceTask
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate                rdfs:label ;
        rr:objectMap [
            rr:constant             "service task" ;
            rr:language             "en"
        ]
    ] ;
    
    rr:predicateObjectMap [
        rr:predicate                rdfs:comment ;
        rr:objectMap [
            rr:constant             "A Service Task is a Task that uses some sort of service, which could be a Web service or an automated application." ;
            rr:language             "en"
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate                    bbo:name ;
        rr:objectMap [
            rml:reference               "@name" ;
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate        teamingAI:belongsToProcess ;
        rr:objectMap [
            rr:parentTriplesMap teamingAI:ProcessMapping
        ]
    ]  .





teamingAI:UserTaskMapping
    a   rr:TriplesMap ;

    rml:logicalSource [
        rml:source                  "" ;
        rml:referenceFormulation    ql:XPath ;
        rml:iterator                "/*[name()='bpmn:definitions']/*[name()='bpmn:process']//*[name()='bpmn:userTask']"
    ] ;

    rr:subjectMap [
        rr:template                 "https://www.teamingai-project.eu/kg/process/qualityInspection/{@id}"
    ] ;

    rr:predicateObjectMap [
        rr:predicate                rdfs:subClassOf ;
        rr:objectMap [
            rr:constant             bbo:UserTask
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate                rdfs:label ;
        rr:objectMap [
            rr:constant             "user task" ;
            rr:language             "en"
        ]
    ] ;
    
    rr:predicateObjectMap [
        rr:predicate                rdfs:comment ;
        rr:objectMap [
            rr:constant             "A User Task is a typical “workflow” Task where a human performer performs the Task with the assistance of a software application and is scheduled through a task list manager of some sort." ;
            rr:language             "en"
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate                    bbo:name ;
        rr:objectMap [
            rml:reference               "@name" ;
        ]
    ]  ;

    rr:predicateObjectMap [
        rr:predicate        teamingAI:belongsToProcess ;
        rr:objectMap [
            rr:parentTriplesMap teamingAI:ProcessMapping
        ]
    ] .





