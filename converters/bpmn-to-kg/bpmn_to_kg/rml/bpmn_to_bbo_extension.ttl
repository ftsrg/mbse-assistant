    ] ;

    rr:predicateObjectMap [
        rr:predicate                rdfs:subClassOf ;
        rr:objectMap [
            rr:constant             bbo:conditionExpression
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate                rdfs:comment ;
        rr:objectMap [
            rr:constant             "A conditionExpression defines when a flow is taken. It is a boolean expression that can access the process variables and compare them with literals or other variables. The condition is fulfilled when the expression returns true." ;
            rr:language             "en"
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate                bbo:xsi_type ;
        rr:objectMap [
            rml:reference           "@*[local-name()='type']"
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate                bbo:expression ;
        rr:objectMap [
            rml:reference           "text()"
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate                teamingAI:belongsToChoreographySequenceFlow ;
        rr:objectMap [
            rr:parentTriplesMap     teamingAI:ChoreographySequenceFlowMapping ;
            rr:joinCondition [
                rr:child            "../@id" ;
                rr:parent           "@id"
            ]
        ]
    ] .

