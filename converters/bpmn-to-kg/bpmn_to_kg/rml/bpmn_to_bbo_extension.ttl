# choreographySequenceFlowConditionExpression
# Summary parent: choreography/sequenceFlow
# Summary attributes: xsi:type
# Summary text content: expression
#
#################################################################################################################

teamingAI:ChoreographySequenceFlowConditionExpressionMapping
    a rr:TriplesMap ;

    rml:logicalSource [
        rml:source                  "/home/bachhofner/Dev/business-process-management-to-knowledge-graph/bpmn/farplas/process_without_messages.bpmn" ;
        rml:referenceFormulation    ql:XPath ;
