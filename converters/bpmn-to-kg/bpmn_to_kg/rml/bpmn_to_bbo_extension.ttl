        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate                rdfs:label ;
        rr:objectMap [
            rr:constant             "data object reference" ;
            rr:language             "en" 
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate                bbo:name ;
        rr:objectMap [
            rml:reference           "@name"
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate                teamingAI:belongsToProcess ;
        rr:objectMap [
            rr:parentTriplesMap     teamingAI:ProcessMapping
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate                bboExtension:dataObjectRef ;
        rr:objectMap [
            rr:template             "https://www.teamingai-project.eu/kg/process/qualityInspection/{@dataObjectRef}"
        ]
    ]
.


