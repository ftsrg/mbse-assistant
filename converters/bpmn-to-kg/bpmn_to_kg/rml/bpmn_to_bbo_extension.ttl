

###################################################################################################################################################
# EXTENSION
###################################################################################################################################################



@prefix teamingAI:          <https://www.teamingai-project.eu/> .

@prefix rml:                <http://semweb.mmlab.be/ns/rml#> .

@prefix rr:                 <http://www.w3.org/ns/r2rml#> .

@prefix ql:                 <http://semweb.mmlab.be/ns/ql#> .

@prefix rdf:                <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .

@prefix rdfs:               <http://www.w3.org/2000/01/rdf-schema#> .

@prefix schema:             <http://schema.org/> .

@prefix dbo:                <http://dbpedia.org/ontology/> .

@prefix bboExtension:       <https://www.teamingai-project.eg/BBOExtension#>.

@prefix bbo:                <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .

@prefix dc:                 <http://purl.org/dc/elements/1.1/> .



bboExtension:
    dc:title        "BPMN to BBO Extension"@en ;
    dc:date         "2021-11-04" ;
    dc:description  "This is the RML mapping from Business Process Model and Notation (BPMN) to Business Process Model and Notation Based Ontology Extension (BBOExt)"@en .



#################################################################################################################
#
# Association Mappings
#
#################################################################################################################



teamingAI:ProcessAssociationMapping
    a   rr:TriplesMap ;

    rml:logicalSource [
        rml:source                  "/home/bachhofner/Dev/business-process-management-to-knowledge-graph/bpmn/farplas/process_without_messages.bpmn" ;
        rml:referenceFormulation    ql:XPath ;
        rml:iterator                "/*[name()='bpmn:definitions']/*[name()='bpmn:process']/*[name()='bpmn:association']"
    ] ;

    rr:subjectMap [
        rr:template                 "https://www.teamingai-project.eu/kg/process/qualityInspection/{@id}"
    ] ;

    rr:predicateObjectMap [
        rr:predicate                rdfs:subClassOf ;
        rr:objectMap [
            rr:constant             bboExtension:Association
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate        teamingAI:belongsToProcess ;
        rr:objectMap [
            rr:parentTriplesMap teamingAI:ProcessMapping
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate                bbo:has_sourceRef ;
        rr:objectMap [
            rr:template             "https://www.teamingai-project.eu/kg/process/qualityInspection/{@sourceRef}"
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate                bbo:has_targetRef ;
        rr:objectMap [
            rr:template             "https://www.teamingai-project.eu/kg/process/qualityInspection/{@targetRef}"
        ]
    ] .





teamingAI:ProcessTextAnnotationMapping
    a   rr:TriplesMap ;

    rml:logicalSource [
        rml:source                      "/home/bachhofner/Dev/business-process-management-to-knowledge-graph/bpmn/farplas/process_without_messages.bpmn" ;
        rml:referenceFormulation        ql:XPath ;
        rml:iterator                    "/*[name()='bpmn:definitions']/*[name()='bpmn:process']/*[name()='bpmn:textAnnotation']" ;
    ] ;

    rr:subjectMap [
        rr:template                     "https://www.teamingai-project.eu/kg/process/qualityInspection/{@id}"
    ] ;

    rr:predicateObjectMap [
        rr:predicate                    rdfs:subClassOf ;
        rr:objectMap [
            rr:constant                 bboExtension:TextAnnotation
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate        teamingAI:belongsToProcess ;
        rr:objectMap [
            rr:parentTriplesMap teamingAI:ProcessMapping
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate                    rdfs:label ;
        rr:objectMap [
            rr:constant                 "text annotation" ;
            rr:language                 "en"
        ]
    ] ;


    rr:predicateObjectMap [
        rr:predicate                    rdfs:comment ;
        rr:objectMap [
            rr:template                 "{*[text()]}" ;
            rr:language                 "en"
        ]
    ] .


teamingAI:ProcessDataObjectMapping
    a   rr:TriplesMap ;

    rml:logicalSource [
        rml:source                  "/home/bachhofner/Dev/business-process-management-to-knowledge-graph/bpmn/farplas/process_without_messages.bpmn" ;
        rml:referenceFormulation    ql:XPath ;
        rml:iterator                "/*[name()='bpmn:definitions']/*[name()='bpmn:process']//*[name()='bpmn:dataObject']"
    ] ;

    rr:subjectMap [
        rr:template                 "https://www.teamingai-project.eu/kg/process/qualityInspection/{@id}"
    ] ;

    rr:predicateObjectMap [
        rr:predicate                rdfs:subClassOf ;
        rr:objectMap [
            rr:constant             bboExtension:DataObject
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate                rdfs:label ;
        rr:objectMap [
            rr:constant             "data object" ;
            rr:language             "en" 
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate                teamingAI:belongsToProcess ;
        rr:objectMap [
            rr:parentTriplesMap     teamingAI:ProcessMapping
        ]
    ]
.



teamingAI:ProcessDataObjectReferenceMapping
    a   rr:TriplesMap ;

    rml:logicalSource [
        rml:source                  "/home/bachhofner/Dev/business-process-management-to-knowledge-graph/bpmn/farplas/process_without_messages.bpmn" ;
        rml:referenceFormulation    ql:XPath ;
        rml:iterator                "/*[name()='bpmn:definitions']/*[name()='bpmn:process']//*[name()='bpmn:dataObjectReference']"
    ] ;

    rr:subjectMap [
        rr:template                 "https://www.teamingai-project.eu/kg/process/qualityInspection/{@id}"
    ] ;

    rr:predicateObjectMap [
        rr:predicate                rdfs:subClassOf ;
        rr:objectMap [
