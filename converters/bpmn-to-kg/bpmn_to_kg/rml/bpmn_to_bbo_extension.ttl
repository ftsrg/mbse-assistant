#################################################################################################################
#
# Pool-like Collaboration Mappings
#
#################################################################################################################

teamingAI:ProcessPoolLikeCollaborationMapping
    a rr:TriplesMap ;

    rml:logicalSource [
        rml:source                      "/home/bachhofner/Dev/business-process-management-to-knowledge-graph/bpmn/farplas/process_without_messages.bpmn" ;
        rml:referenceFormulation        ql:XPath ;
        rml:iterator                    "/*[name()='bpmn:definitions']/*[name()='bpmn:process']//*[name()='bpmn:collaboration']"
    ] ;

    rr:subjectMap [
        rr:template                     "https://www.teamingai-project.eu/kg/process/qualityInspection/{@id}"
    ] ;

    rr:predicateObjectMap [
        rr:predicate                    rdfs:subClassOf ;
        rr:objectMap [
            rr:constant                 bboExtension:Collaboration
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate        teamingAI:belongsToProcess ;
        rr:objectMap [
            rr:parentTriplesMap teamingAI:ProcessMapping
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate                    rdfs:label ;
        rr:objectMap [
            rr:constant                 "pool" ;
            rr:language                 "en"
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate                    rdfs:comment ;
        rr:objectMap [
            rr:constant                 "A Pool is the graphical representation of a Participant in a Collaboration. A Participant (see page 114) can be a specific PartnerEntity (e.g., a company) or can be a more general PartnerRole (e.g., a buyer, seller, or manufacturer). A Pool MAY or MAY NOT reference a Process. A Pool is NOT REQUIRED to contain a Process, i.e., it can be a “black box.”" ;
            rr:language                 "en"
        ]
    ] .





teamingAI:ProcessLaneSetMapping
    a   rr:TriplesMap ;

    rml:logicalSource [
        rml:source                  "/home/bachhofner/Dev/business-process-management-to-knowledge-graph/bpmn/farplas/process_without_messages.bpmn" ;
        rml:referenceFormulation    ql:XPath ;
        rml:iterator                "/*[name()='bpmn:definitions']/*[name()='bpmn:process']/*[name()='bpmn:laneSet']"
    ] ;

    rr:subjectMap [
        rr:template                 "https://www.teamingai-project.eu/kg/process/qualityInspection/{@id}"
    ] ;

    rr:predicateObjectMap [
        rr:predicate                rdfs:subClassOf ;
        rr:objectMap [
            rr:constant             bboExtension:LaneSet
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate        teamingAI:belongsToProcess ;
        rr:objectMap [
            rr:parentTriplesMap teamingAI:ProcessMapping
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate                rdfs:label ;
        rr:objectMap [
            rr:constant             "lane set" ;
            rr:language             "en"
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate                rdfs:comment ;
        rr:objectMap [
            rr:constant             "The Lane Set element defines the container for one or more Lanes. A Process can contain one or more Lane Sets." ;
            rr:language             "en"
        ]
    ] .





teamingAI:ProcessLaneMapping
    a   rr:TriplesMap ;

    rml:logicalSource [
        rml:source                  "/home/bachhofner/Dev/business-process-management-to-knowledge-graph/bpmn/farplas/process_without_messages.bpmn" ;
        rml:referenceFormulation    ql:XPath ;
        rml:iterator                "/*[name()='bpmn:definitions']/*[name()='bpmn:process']/*[name()='bpmn:laneSet']/*[name()='bpmn:lane']"
    ] ;

    rr:subjectMap [
        rr:template                 "https://www.teamingai-project.eu/kg/process/qualityInspection/{@id}"
    ] ;

    rr:predicateObjectMap [
        rr:predicate                rdfs:subClassOf ;
        rr:objectMap [
            rr:constant             bboExtension:Lane
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate        teamingAI:belongsToProcess ;
        rr:objectMap [
            rr:parentTriplesMap teamingAI:ProcessMapping
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate                rdfs:label ;
        rr:objectMap [
            rr:constant             "lane" ;
            rr:language             "en"
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate                rdfs:comment ;
        rr:objectMap [
            rr:constant             "A Lane is a sub-partition within a Process (often within a Pool) and will extend the entire length of the Process level, either vertically or horizontally. When a Lane is defined it is contained within a LaneSet, which is contained within a Process." ;
            rr:language             "en"
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate                bbo:has_activity ;
        rr:objectMap [
            rr:template           "https://www.teamingai-project.eu/kg/process/qualityInspection/{*[text()]}"
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate                    bbo:name ;
        rr:objectMap [
            rml:reference               "@name" ;
        ]
    ] .



teamingAI:ProcessParticipantMapping
    a   rr:TriplesMap ;

     rml:logicalSource [
        rml:source                  "/home/bachhofner/Dev/business-process-management-to-knowledge-graph/bpmn/farplas/process_without_messages.bpmn" ;
        rml:referenceFormulation   ql:XPath ;
        rml:iterator                "/*[name()='bpmn:definitions']/*[name()='bpmn:process']//*[name()='bpmn:collaboration']/*[name()='bpmn:participant']" ;
    ] ;

    rr:subjectMap [
        rr:template                 "https://www.teamingai-project.eu/kg/process/qualityInspection/{@id}" ;
    ] ;

    rr:predicateObjectMap [
        rr:predicate        rdfs:subClassOf ;
        rr:objectMap    [
            rr:constant     bboExtension:Participant
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate    teamingAI:belongsToProcess ;
        rr:objectMap [
            rr:parentTriplesMap     teamingAI:ProcessMapping
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate    rdfs:label ;
        rr:objectMap [
            rr:constant     "participant" ; 
            rr:language     "en"
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate    rdfs:comment ;
        rr:objectMap [
            rr:constant     "A Participant represents a specific PartnerEntity (e.g., a company) and/or a more general PartnerRole (e.g., a buyer, seller, or manufacturer) that are Participants in a Collaboration. A Participant is often responsible for the execution of the Process enclosed in a Pool; however, a Pool MAY be defined without a Process" ;
            rr:language     "en"
        ] 
    ] ;
    
    rr:predicateObjectMap [
        rr:predicate    bbo:name ;
        rr:objectMap [
            rml:reference   "@name"
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate    bboExtension:processRef ;
        rr:objectMap [
            rr:template     "{@processRef}" 
        ]
    ]
.



teamingAI:ProcessMessageFlowMapping
    a   rr:TriplesMap ;

     rml:logicalSource [
        rml:source                  "/home/bachhofner/Dev/business-process-management-to-knowledge-graph/bpmn/farplas/process_without_messages.bpmn" ;
        rml:referenceFormulation   ql:XPath ;
        rml:iterator                "/*[name()='bpmn:definitions']/*[name()='bpmn:process']/*[name()='bpmn:collaboration']/*[name()='bpmn:messageFlow']" ;
    ] ;

    rr:subjectMap [
        rr:template                 "https://www.teamingai-project.eu/kg/process/qualityInspection/{@id}" ;
    ] ;

    rr:predicateObjectMap [
        rr:predicate        rdfs:subClassOf ;
        rr:objectMap    [
            rr:constant     bboExtension:MessageFlow
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate    teamingAI:belongsToProcess ;
        rr:objectMap [
            rr:parentTriplesMap     teamingAI:ProcessMapping
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate    rdfs:label ;
        rr:objectMap [
            rr:constant     "message flow" ; 
            rr:language     "en"
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate    rdfs:comment ;
        rr:objectMap [
            rr:constant     "A Message Flow is used to show the flow of Messages between two Participants that are prepared to send and receive them." ;
            rr:language     "en"
        ] 
    ] ;
    
    rr:predicateObjectMap [
        rr:predicate    bbo:name ;
        rr:objectMap [
            rml:reference   "@name"
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate                bbo:has_sourceRef ;
        rr:objectMap [
            rr:template             "https://www.teamingai-project.eu/kg/process/qualityInspection/{@sourceRef}"
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate        bbo:has_targetRef ;
        rr:objectMap [
            rr:template     "https://www.teamingai-project.eu/kg/process/qualityInspection/{@targetRef}" ;
        ]
    ]
.








































#################################################################################################################
#
# Extended mappings appended after the original file
# Source of extension: element inventory extracted from the BPMN corpus summary
# IMPORTANT: original bpmn_to_bbo_extension.ttl content above is kept unchanged for diff inspection
#
#################################################################################################################


#################################################################################################################
#
# collaborationAssociation
# Summary parent: collaboration
# Other attributes intentionally omitted for now: id, associationDirection, sourceRef, targetRef
#
#################################################################################################################

teamingAI:CollaborationAssociationMapping
    a   rr:TriplesMap ;

    rml:logicalSource [
        rml:source                      "/home/bachhofner/Dev/business-process-management-to-knowledge-graph/bpmn/farplas/process_without_messages.bpmn" ;
        rml:referenceFormulation        ql:XPath ;
        rml:iterator                    "/*[name()='bpmn:definitions']//*[name()='bpmn:collaboration']/*[name()='bpmn:association']" ;
    ] ;

    rr:subjectMap [
        rr:template                     "https://www.teamingai-project.eu/kg/process/qualityInspection/{@id}"
    ] ;

    rr:predicateObjectMap [
        rr:predicate                    rdfs:subClassOf ;
        rr:objectMap [ rr:constant bboExtension:Association ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate                    teamingAI:belongsToCollaboration ;
        rr:objectMap [
            rr:parentTriplesMap         teamingAI:CollaborationMapping ;
            rr:joinCondition [
                rr:child                "../@id" ;
                rr:parent               "@id"
            ]
        ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate                    bbo:id ;
        rr:objectMap [ rml:reference "@id" ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate                    bboExtension:associationDirection ;
        rr:objectMap [ rml:reference "@associationDirection" ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate                    bbo:sourceRef ;
        rr:objectMap [ rml:reference "@sourceRef" ]
    ] ;

    rr:predicateObjectMap [
        rr:predicate                    bbo:targetRef ;
        rr:objectMap [ rml:reference "@targetRef" ]
    ] .


#################################################################################################################
